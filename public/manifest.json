   {
  "manifest_version": 2,
  "name": "YoumuLoader",
  "version": "1.0",

  "description": "Needed for downloading youtube videos using a jellyfin plugin",

  "icons": {
    "64": "favicon.ico"
  },

  "browser_action": {
    "default_title": "Youmu Loader",
    "default_popup": "index.html"
  },

  "permissions": [
    "activeTab",
    "storage"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "youmuloader@github.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}